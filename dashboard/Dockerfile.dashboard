FROM node:20-alpine

LABEL maintainer="Fanalogy" \
    description="Intellify Dashboard — Vite/React dev server"

WORKDIR /app

# Copy package files first for layer cache
COPY package.json package-lock.json ./
RUN npm ci --silent

# Copy source
COPY . .

EXPOSE 5175

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5175"]
