# ============================================
# Intellify Enterprise Hub - Environment Config
# ============================================

# ─── Intellify Local & Cloud Ports ────────
MCP_HUB_PORT=8080
DASHBOARD_PORT=5173

# ─── NPU-STACK Integration ────────────────
# Point this to the running instance of NPU-STACK to process training & deployment tasks
NPU_STACK_API_URL=http://127.0.0.1:8000

# ─── Mock Database / State ────────────────
REDIS_MOCK_ENABLED=true
