# ============================================
# Intellify Enterprise Hub - Environment Config
# ============================================

# ─── Intellify Services ───────────────────
MCP_HUB_HOST=0.0.0.0
MCP_HUB_PORT=8080

# Dashboard runs on 5175 (5173/5174 reserved for promo-site / other frontends)
DASHBOARD_PORT=5175

# ─── NPU-STACK Integration ────────────────
# Point this to a running NPU-STACK instance to process training & deployment tasks
NPU_STACK_API_URL=http://127.0.0.1:8000

# ─── Ingestion Service ────────────────────
INGESTION_SCAN_ROOT=./test_data
INGESTION_OUTPUT_DIR=./data/ingested
INGESTION_MIN_CONFIDENCE=0.80
